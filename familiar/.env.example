# Copy this file to .env and fill in your values.
# The server reads these on startup via dotenvy.

# ── Required ──────────────────────────────────────────────────────────────────

# Telegram Bot API token — get one from @BotFather
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the HTTP server listens on (default: 8080)
# PORT=8080

# System prompt prepended to every conversation
# SYSTEM_PROMPT=You are a helpful assistant running on a personal server.

# Webhook secret — any random string, must match the value passed to
# Telegram's setWebhook call.  Strongly recommended in production.
# Generate one with: openssl rand -hex 32
# WEBHOOK_SECRET=
