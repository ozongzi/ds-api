# Copy this file to .env and fill in your values.
# The server reads these on startup via dotenvy.

# ── Required ──────────────────────────────────────────────────────────────────

# DeepSeek API key — from platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API key — used for embeddings (openai/text-embedding-3-small)
# Get yours at openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL connection URL (with pgvector extension installed)
# Example: postgres://familiar:password@localhost:5432/familiar
DATABASE_URL=postgres://user:password@localhost:5432/familiar

# ── Optional ──────────────────────────────────────────────────────────────────

# Port for the HTTP server (default: 3000)
# PORT=3000

# System prompt prepended to every conversation
# SYSTEM_PROMPT=You are a helpful personal assistant.

# Log level (error / warn / info / debug / trace)
# RUST_LOG=info
